#!/bin/bash

## PBS template for batchtools
##
## Template variables (populated by batchtools):
##   <%= resources$ncpus %>      - Number of CPUs
##   <%= resources$memory %>     - Memory in MB
##   <%= resources$walltime %>   - Walltime (HH:MM:SS)
##   <%= resources$queue %>      - PBS queue name
##   <%= job.name %>             - Job name
##   <%= log.file %>             - Path to log file
##   <%= resources$email %>      - Email address (optional)

#PBS -N <%= job.name %>
#PBS -l select=1:ncpus=<%= resources$ncpus %>:mem=<%= resources$memory %>mb
#PBS -l walltime=<%= resources$walltime %>
#PBS -q <%= resources$queue %>
#PBS -o <%= log.file %>
#PBS -e <%= log.file %>

## Email notifications (optional)
<% if (!is.null(resources$email)) { %>
#PBS -M <%= resources$email %>
#PBS -m abe
<% } %>

## Load required modules
module purge
module load app/R/4.4.1
module load app/gcc/gcc-13.2.0

## Set up R library and JAGS paths
export R_LIBS_USER=~/R_libs:${R_LIBS_USER}
export PATH="$HOME/local/jags/bin:$PATH"
export LD_LIBRARY_PATH="$HOME/local/jags/lib:$LD_LIBRARY_PATH"
export PKG_CONFIG_PATH="$HOME/local/jags/lib/pkgconfig:$PKG_CONFIG_PATH"

## Change to working directory
cd <%= getwd() %>

## Log job information
echo "======================================"
echo "Job name: <%= job.name %>"
echo "Job ID: ${PBS_JOBID}"
echo "Node: $(hostname)"
echo "Cores: <%= resources$ncpus %>"
echo "Memory: <%= resources$memory %> MB"
echo "Start time: $(date)"
echo "======================================"
echo ""

## Run the R command generated by batchtools
<%= chunk.header %>
Rscript -e '<%= rscript %>'
<%= chunk.footer %>

## Log completion
EXIT_CODE=$?
echo ""
echo "======================================"
echo "End time: $(date)"
echo "Exit code: ${EXIT_CODE}"
echo "======================================"

exit ${EXIT_CODE}
